==> My approach:
--Split each word in the contents column into a separate row
WITH SplitContent AS (
SELECT g1.filename
     , TRIM('.,!?;:"()' FROM g2.value) AS split_word
FROM google_file_store AS g1
CROSS APPLY STRING_SPLIT(g1.contents, ' ') AS g2
)
--Calculate occurrencies per word
SELECT split_word AS word
     , COUNT(*) AS occurrences
FROM SplitContent
GROUP BY split_word
ORDER BY occurrences DESC ;
