==> My approach:
--Rank the products per category by sales qty, rating
WITH ProductRanking AS (
SELECT p.category_name 
    , p.product_name
    , DENSE_RANK() OVER (PARTITION BY p.category_name ORDER BY s.sales_quantity DESC, s.rating DESC) AS ranking
FROM products AS p 
LEFT JOIN product_sales AS s 
   ON p.product_id = s.product_id
)
SELECT category_name
     , product_name
FROM ProductRanking
WHERE ranking = 1
ORDER BY category_name
       , product_name ;
