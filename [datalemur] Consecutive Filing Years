==> My approach:
--Order the filing history by user and by month
WITH FilingOrder AS (
SELECT *
     , ROW_NUMBER() OVER (PARTITION BY user_id ORDER BY filing_date) AS rn
FROM filed_taxes  
WHERE product LIKE '%TurboTax%'
)
--Identify streak group per user
, StreakGroup AS (
SELECT *
     , EXTRACT(year FROM filing_date) - rn AS streak_group
FROM FilingOrder
)
--Filter users with at least 3 consecutive years of filing transactions
SELECT DISTINCT user_id
FROM StreakGroup
GROUP BY user_id
       , streak_group
HAVING COUNT(*) >= 3
ORDER BY user_id ;
